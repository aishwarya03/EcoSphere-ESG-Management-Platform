generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
  PRODUCT
}

enum ProductType {
  PHYSICAL_GOOD
  SERVICE
}

enum ProfileStatus {
  DRAFT
  PUBLISHED
}

enum EsgPillar {
  ENVIRONMENTAL
  SOCIAL
  GOVERNANCE
}

enum EmissionSourceType {
  PURCHASE
  MANUFACTURING
  EXPENSE
  FLEET
  ELECTRICITY
  OTHER
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  MISSED
  ARCHIVED
}

enum PolicyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BadgeMetric {
  XP_TOTAL
  CHALLENGES_COMPLETED
  CSR_PARTICIPATIONS_COMPLETED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  departments        Department[]
  categories         Category[]
  esgConfig          ESGConfiguration?
  products           Product[]
  emissionFactors    EmissionFactor[]
  environmentalGoals EnvironmentalGoal[]
  esgPolicies        ESGPolicy[]
  badges             Badge[]
  rewards            Reward[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  email    String  @unique
  username String? @unique

  passwordHash String?

  role   Role       @default(EMPLOYEE)
  status UserStatus @default(PENDING)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  inviteTokenHash      String?   @unique
  inviteTokenExpiresAt DateTime?

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  headOfDepartments Department[] @relation("DepartmentHead")

  @@index([organizationId])
  @@index([departmentId])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name   String
  code   String
  status EntityStatus @default(ACTIVE)

  headUserId String?
  head       User?   @relation("DepartmentHead", fields: [headUserId], references: [id])

  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")

  employees          User[]
  environmentalGoals EnvironmentalGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentDepartmentId])
}

model Category {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name   String
  type   CategoryType
  status EntityStatus @default(ACTIVE)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name, type])
  @@index([organizationId])
}

model ESGConfiguration {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  environmentalWeight Int @default(40)
  socialWeight        Int @default(30)
  governanceWeight    Int @default(30)

  autoEmissionCalculation Boolean @default(false)
  evidenceRequired        Boolean @default(false)
  badgeAutoAward          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  code        String
  type        ProductType
  description String?
  status      EntityStatus @default(ACTIVE)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  esgProfiles ProductEsgProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
}

model ProductEsgProfile {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  version               Int
  assessedAt            DateTime      @default(now())
  carbonFootprintKgCo2e Float?
  overallScore          Float?
  notes                 String?
  status                ProfileStatus @default(DRAFT)

  metrics ProductEsgMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, version])
  @@index([productId])
}

model ProductEsgMetric {
  id        String            @id @default(cuid())
  profileId String
  profile   ProductEsgProfile @relation(fields: [profileId], references: [id])

  pillar EsgPillar
  name   String
  value  String
  unit   String?

  createdAt DateTime @default(now())

  @@index([profileId])
}

model EmissionFactor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  sourceType  EmissionSourceType
  unit        String
  co2ePerUnit Float

  validFrom DateTime?
  validTo   DateTime?
  source    String?

  status EntityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model EnvironmentalGoal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title         String
  description   String?
  targetMetric  String
  baselineValue Float?
  targetValue   Float
  unit          String

  startDate  DateTime
  targetDate DateTime

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  status GoalStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departmentId])
}

model ESGPolicy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title         String
  category      String
  description   String?
  version       Int          @default(1)
  effectiveDate DateTime
  status        PolicyStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Badge {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  description String?
  icon        String?

  unlockMetric    BadgeMetric
  unlockThreshold Int

  status EntityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Reward {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name           String
  description    String?
  pointsRequired Int
  stock          Int

  status EntityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}
