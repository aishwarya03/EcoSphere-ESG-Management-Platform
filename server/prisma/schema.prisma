generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
  PRODUCT
}

enum ProductType {
  PHYSICAL_GOOD
  SERVICE
}

enum ProfileStatus {
  DRAFT
  PUBLISHED
}

enum EsgPillar {
  ENVIRONMENTAL
  SOCIAL
  GOVERNANCE
}

enum EmissionSourceType {
  PURCHASE
  MANUFACTURING
  EXPENSE
  FLEET
  ELECTRICITY
  OTHER
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  MISSED
  ARCHIVED
}

enum PolicyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BadgeMetric {
  XP_TOTAL
  CHALLENGES_COMPLETED
  CSR_PARTICIPATIONS_COMPLETED
}

enum ParticipationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  COMPLETED
  ARCHIVED
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  departments        Department[]
  categories         Category[]
  esgConfig          ESGConfiguration?
  products           Product[]
  emissionFactors    EmissionFactor[]
  environmentalGoals EnvironmentalGoal[]
  esgPolicies        ESGPolicy[]
  badges             Badge[]
  rewards            Reward[]

  carbonTransactions      CarbonTransaction[]
  csrActivities           CSRActivity[]
  employeeParticipations  EmployeeParticipation[]
  challenges              Challenge[]
  challengeParticipations ChallengeParticipation[]
  policyAcknowledgements  PolicyAcknowledgement[]
  audits                  Audit[]
  complianceIssues        ComplianceIssue[]
  departmentScores        DepartmentScore[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  email    String  @unique
  username String? @unique

  passwordHash String?

  role   Role       @default(EMPLOYEE)
  status UserStatus @default(PENDING)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  inviteTokenHash      String?   @unique
  inviteTokenExpiresAt DateTime?

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  headOfDepartments Department[] @relation("DepartmentHead")

  carbonTransactionsCreated CarbonTransaction[]

  csrParticipations         EmployeeParticipation[] @relation("CsrParticipationEmployee")
  reviewedCsrParticipations EmployeeParticipation[] @relation("CsrParticipationReviewer")

  challengeParticipations         ChallengeParticipation[] @relation("ChallengeParticipationEmployee")
  reviewedChallengeParticipations ChallengeParticipation[] @relation("ChallengeParticipationReviewer")

  policyAcknowledgements PolicyAcknowledgement[]
  ownedComplianceIssues  ComplianceIssue[]

  @@index([organizationId])
  @@index([departmentId])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name   String
  code   String
  status EntityStatus @default(ACTIVE)

  headUserId String?
  head       User?   @relation("DepartmentHead", fields: [headUserId], references: [id])

  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")

  employees          User[]
  environmentalGoals EnvironmentalGoal[]

  carbonTransactions CarbonTransaction[]
  csrActivities      CSRActivity[]
  audits             Audit[]
  scores             DepartmentScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([parentDepartmentId])
}

model Category {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name   String
  type   CategoryType
  status EntityStatus @default(ACTIVE)

  products      Product[]
  csrActivities CSRActivity[]
  challenges    Challenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name, type])
  @@index([organizationId])
}

model ESGConfiguration {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  environmentalWeight Int @default(40)
  socialWeight        Int @default(30)
  governanceWeight    Int @default(30)

  autoEmissionCalculation Boolean @default(false)
  evidenceRequired        Boolean @default(false)
  badgeAutoAward          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  code        String
  type        ProductType
  description String?
  status      EntityStatus @default(ACTIVE)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  esgProfiles ProductEsgProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
}

model ProductEsgProfile {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  version               Int
  assessedAt            DateTime      @default(now())
  carbonFootprintKgCo2e Float?
  overallScore          Float?
  notes                 String?
  status                ProfileStatus @default(DRAFT)

  metrics ProductEsgMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, version])
  @@index([productId])
}

model ProductEsgMetric {
  id        String            @id @default(cuid())
  profileId String
  profile   ProductEsgProfile @relation(fields: [profileId], references: [id])

  pillar EsgPillar
  name   String
  value  String
  unit   String?

  createdAt DateTime @default(now())

  @@index([profileId])
}

model EmissionFactor {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  sourceType  EmissionSourceType
  unit        String
  co2ePerUnit Float

  validFrom DateTime?
  validTo   DateTime?
  source    String?

  status EntityStatus @default(ACTIVE)

  carbonTransactions CarbonTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model EnvironmentalGoal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title         String
  description   String?
  targetMetric  String
  baselineValue Float?
  targetValue   Float
  unit          String

  startDate  DateTime
  targetDate DateTime

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  status GoalStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departmentId])
}

model ESGPolicy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title         String
  category      String
  description   String?
  version       Int          @default(1)
  effectiveDate DateTime
  status        PolicyStatus @default(DRAFT)

  acknowledgements PolicyAcknowledgement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Badge {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  description String?
  icon        String?

  unlockMetric    BadgeMetric
  unlockThreshold Int

  status EntityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Reward {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name           String
  description    String?
  pointsRequired Int
  stock          Int

  status EntityStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model CarbonTransaction {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  emissionFactorId String
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id])

  quantity                  Float
  calculatedEmissionsKgCo2e Float
  transactionDate           DateTime
  notes                     String?

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departmentId])
  @@index([emissionFactorId])
}

model CSRActivity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title       String
  description String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  pointsValue Int
  startDate   DateTime
  endDate     DateTime?
  status      EntityStatus @default(ACTIVE)

  participations EmployeeParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departmentId])
}

model EmployeeParticipation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  csrActivityId String
  csrActivity   CSRActivity @relation(fields: [csrActivityId], references: [id])

  employeeId String
  employee   User   @relation("CsrParticipationEmployee", fields: [employeeId], references: [id])

  proof          String?
  approvalStatus ParticipationStatus @default(PENDING)
  pointsEarned   Int?
  completionDate DateTime

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  reviewedByUserId String?
  reviewedByUser   User?   @relation("CsrParticipationReviewer", fields: [reviewedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, csrActivityId])
  @@index([organizationId])
  @@index([csrActivityId])
  @@index([employeeId])
}

model Challenge {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title       String
  description String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  xp               Int
  difficulty       ChallengeDifficulty
  evidenceRequired Boolean             @default(false)
  deadline         DateTime
  status           ChallengeStatus     @default(DRAFT)

  participations ChallengeParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model ChallengeParticipation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])

  employeeId String
  employee   User   @relation("ChallengeParticipationEmployee", fields: [employeeId], references: [id])

  progress       Int                 @default(0)
  proof          String?
  approvalStatus ParticipationStatus @default(PENDING)
  xpAwarded      Int?

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  reviewedByUserId String?
  reviewedByUser   User?   @relation("ChallengeParticipationReviewer", fields: [reviewedByUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, challengeId])
  @@index([organizationId])
  @@index([challengeId])
  @@index([employeeId])
}

model PolicyAcknowledgement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  esgPolicyId String
  esgPolicy   ESGPolicy @relation(fields: [esgPolicyId], references: [id])

  employeeId String
  employee   User   @relation(fields: [employeeId], references: [id])

  policyVersion  Int
  acknowledgedAt DateTime @default(now())

  @@unique([employeeId, esgPolicyId, policyVersion])
  @@index([organizationId])
  @@index([esgPolicyId])
}

model Audit {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title       String
  description String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  auditor         String?
  auditDate       DateTime
  status          AuditStatus @default(PLANNED)
  findingsSummary String?

  complianceIssues ComplianceIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([departmentId])
}

model ComplianceIssue {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  auditId String
  audit   Audit  @relation(fields: [auditId], references: [id])

  severity    IssueSeverity
  description String

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  dueDate DateTime
  status  IssueStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([auditId])
  @@index([ownerId])
}

model DepartmentScore {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  environmentalScore Float
  socialScore        Float
  governanceScore    Float
  totalScore         Float

  computedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([organizationId])
  @@index([departmentId])
}
